rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Consumer App: Users can read/write their own profile
    // Staff Terminal: Can read all users (for directory) and update pawPoints
    match /users/{userId} {
      // Authenticated user can read & write their own doc
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Staff Terminal (unauthenticated) can read all user docs for directory view
      allow read: if true;
      
      // Staff Terminal can update pawPoints on any user doc
      allow update: if true;
    }
    
    // Requests collection: open for both consumer app (create) and staff terminal (read/update/delete)
    match /requests/{document=**} {
      allow read, write: if true; 
    }
    
    // Legacy pointsQueue collection
    match /pointsQueue/{document=**} {
      allow read, write: if true;
    }
  }
}
