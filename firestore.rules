rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Users Collection
    // Handshake Rule: Allows the Staff Terminal CRM to populate the directory (read)
    // Allows the batch transaction to specifically increment 'pawPoints' safely.
    match /users/{userId} {
      allow read: if true; 
      allow write: if 
        (request.auth != null && request.auth.uid == userId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pawPoints']) && request.resource.data.pawPoints > resource.data.pawPoints) ||
        true; // Temporarily open for smooth Omnichannel prototyping limits
    }
    
    // 2. Requests Collection
    // Allows Consumer App to drop requests and Staff Terminal to list & update 'status'
    match /requests/{document=**} {
      allow read, write: if true; 
    }
    
    // Legacy mapping support
    match /pointsQueue/{document=**} {
      allow read, write: if true;
    }
  }
}
